# Telegram Bot API token from @BotFather
BOT_TOKEN=123456789:AAExampleBotTokenHere

# GramJS (Telegram user account API) credentials from https://my.telegram.org
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# 32-byte (64 hex characters) key used for AES-256-GCM session encryption.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=7939b88d085d041e15ed85446447a97dbbce0ecdd47c685ffaddcaf9d02f08ea
# ^ EXAMPLE ONLY — generate your own with the command above, do not reuse this value

# Comma separated Telegram user IDs that are allowed to use admin commands
ADMIN_IDS=123456789,987654321

# SQLite database file path
DB_PATH=./data/database.sqlite

# Directory for log files
LOG_DIR=./logs

# Delay (ms) between posting to each group in a posting cycle. Default: 30000 (30 sec)
GROUP_POST_DELAY_MS=30000

# Optional: auto-create these login/password pairs on every boot if they don't
# exist yet. Useful on platforms with an ephemeral filesystem (e.g. Render free
# tier), where the SQLite file is wiped on every redeploy/restart and manually
# created logins would otherwise disappear. Add as many BOOTSTRAP_USERNAME_N /
# BOOTSTRAP_PASSWORD_N pairs as you need (N = 1, 2, 3, ...); leave a pair's both
# values empty to skip it.
BOOTSTRAP_USERNAME_1=admin1
BOOTSTRAP_PASSWORD_1=admin123

BOOTSTRAP_USERNAME_2=admin2
BOOTSTRAP_PASSWORD_2=admin456

BOOTSTRAP_USERNAME_3=admin3
BOOTSTRAP_PASSWORD_3=admin789

BOOTSTRAP_USERNAME_4=admin4
BOOTSTRAP_PASSWORD_4=admin012

BOOTSTRAP_USERNAME_5=admin5
BOOTSTRAP_PASSWORD_5=admin345

BOOTSTRAP_USERNAME_6=admin6
BOOTSTRAP_PASSWORD_6=admin678

BOOTSTRAP_USERNAME_7=admin7
BOOTSTRAP_PASSWORD_7=admin901

BOOTSTRAP_USERNAME_8=admin8
BOOTSTRAP_PASSWORD_8=admin234