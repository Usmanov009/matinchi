# Telegram Bot API token from @BotFather
BOT_TOKEN=123456789:AAExampleBotTokenHere

# GramJS (Telegram user account API) credentials from https://my.telegram.org
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash_here

# 32-byte (64 hex characters) key used for AES-256-GCM session encryption.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=7939b88d085d041e15ed85446447a97dbbce0ecdd47c685ffaddcaf9d02f08ea
# ^ EXAMPLE ONLY — generate your own with the command above, do not reuse this value

# Comma separated Telegram user IDs that are allowed to use admin commands
ADMIN_IDS=123456789,987654321

# SQLite database file path
DB_PATH=./data/database.sqlite

# Directory for log files
LOG_DIR=./logs

# Delay (ms) between posting to each group in a posting cycle. Default: 60000 (60 sec)
GROUP_POST_DELAY_MS=60000

# Optional: auto-create this login/password on every boot if it doesn't exist yet.
# Useful on platforms with an ephemeral filesystem (e.g. Render free tier), where
# the SQLite file is wiped on every redeploy/restart and manually created logins
# would otherwise disappear. Leave both empty to disable.
BOOTSTRAP_USERNAME=admin
BOOTSTRAP_PASSWORD=admin123